# Copy this file to .env and fill in real values for local development.
# Never commit .env — see .gitignore. No account-specific values belong in code.
#
# This file only lists vars actually read by code that exists today. New vars
# get added here in the same commit that introduces the code reading them —
# see CLAUDE.md "Standing rules". Twilio and web push vars land when those
# features are built (Phase 3 phone-OTP is via Clerk instead of raw Twilio
# Verify — see CLAUDE.md §4 for that decision).

# --- Database (packages/db, apps/api) ---------------------------------------
# Local Postgres connection string. For local dev with Homebrew Postgres:
#   createdb alumni_center_dev
#   DATABASE_URL=postgres://$(whoami)@localhost:5432/alumni_center_dev
DATABASE_URL=postgres://localhost:5432/alumni_center_dev

# Used only by `pnpm test` in apps/api — a separate database so tests can
# freely truncate tables without touching dev data.
TEST_DATABASE_URL=postgres://localhost:5432/alumni_center_test

# --- API (apps/api) -----------------------------------------------------------
PORT=4000
NODE_ENV=development

# Signs staff dashboard login JWTs (apps/admin auth). Generate with:
#   openssl rand -hex 32
# Never reuse across environments — rotate on handoff (see docs/HANDOFF.md).
STAFF_JWT_SECRET=

# Origin the API accepts CORS requests from — the admin dashboard's URL.
ADMIN_APP_ORIGIN=http://localhost:3011

# Origin the API accepts CORS requests from for the member PWA. Unlike
# apps/admin (which never calls the API from the browser), apps/web's Stripe
# Checkout redirect flow and PWA context make some client-side calls
# necessary, so this one is actually exercised by the CORS middleware.
WEB_APP_ORIGIN=http://localhost:3012

# --- Admin dashboard (apps/admin) ----------------------------------------------
# Public URL of the API, no trailing slash.
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- Seed script (apps/api `pnpm db:seed`) -------------------------------------
# Password for the seeded admin login (phone +15025550001). Optional — falls
# back to "changeme123" if unset. Only affects local/throwaway environments;
# never run db:seed against a database with real data (see README.md).
SEED_ADMIN_PASSWORD=

# --- Stripe (apps/api webhook + token purchase, apps/web checkout) ------------
# From https://dashboard.stripe.com/test/apikeys — use TEST mode keys for
# local dev, always. Never commit live keys anywhere, ever.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# From `stripe listen --forward-to localhost:4000/webhooks/stripe` locally
# (Stripe CLI), or the webhook endpoint's signing secret in the dashboard in
# production. Ledger credit happens only on a verified webhook event, never
# on client-side purchase confirmation.
STRIPE_WEBHOOK_SECRET=

# --- Clerk (apps/web member phone-OTP auth) ------------------------------------
# From https://dashboard.clerk.com — enable "Phone number" as a sign-in
# option under User & Authentication > Email, Phone, Username.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Signing secret for Clerk webhooks (svix) — from the webhook endpoint you
# create in the Clerk dashboard pointing at apps/web's /api/webhooks/clerk.
# Used to create an `accounts` row the first time a member signs up.
CLERK_WEBHOOK_SECRET=

# --- QR signing (apps/api scan validation, apps/web card rendering) -----------
# Signs the rotating QR token on The Alumni Card so a screenshot can't be
# reused indefinitely. Generate with: openssl rand -hex 32
QR_SIGNING_SECRET=

# --- Member PWA (apps/web) -----------------------------------------------------
# Public URL of the API, no trailing slash.
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- Scan-station (apps/api kiosk auth, apps/scan-station) ---------------------
# Signs kiosk device tokens (issued once at device registration, see
# POST /kiosk-devices) — deliberately separate from STAFF_JWT_SECRET so a
# stolen/compromised kiosk tablet doesn't also expose the staff dashboard's
# secret. Generate with: openssl rand -hex 32
KIOSK_JWT_SECRET=

# Origin the API accepts CORS requests from for the scan-station app.
SCAN_STATION_APP_ORIGIN=http://localhost:3013

# Public URL of the API, no trailing slash — same value as apps/admin/apps/web.
NEXT_PUBLIC_API_URL=http://localhost:4000
