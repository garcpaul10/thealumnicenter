# Copy this file to .env and fill in real values for local development.
# Never commit .env — see .gitignore. No account-specific values belong in code.
#
# This file only lists vars actually read by code that exists today. New vars
# get added here in the same commit that introduces the code reading them —
# see CLAUDE.md "Standing rules". Phases 2+ will add Stripe, Twilio, web push,
# and QR-signing vars as those features are built.

# --- Database (packages/db, apps/api) ---------------------------------------
# Local Postgres connection string. For local dev with Homebrew Postgres:
#   createdb alumni_center_dev
#   DATABASE_URL=postgres://$(whoami)@localhost:5432/alumni_center_dev
DATABASE_URL=postgres://localhost:5432/alumni_center_dev

# Used only by `pnpm test` in apps/api — a separate database so tests can
# freely truncate tables without touching dev data.
TEST_DATABASE_URL=postgres://localhost:5432/alumni_center_test

# --- API (apps/api) -----------------------------------------------------------
PORT=4000
NODE_ENV=development

# Signs staff dashboard login JWTs (apps/admin auth). Generate with:
#   openssl rand -hex 32
# Never reuse across environments — rotate on handoff (see docs/HANDOFF.md).
STAFF_JWT_SECRET=

# Origin the API accepts CORS requests from — the admin dashboard's URL.
ADMIN_APP_ORIGIN=http://localhost:3011

# --- Admin dashboard (apps/admin) ----------------------------------------------
# Public URL of the API, no trailing slash.
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- Seed script (apps/api `pnpm db:seed`) -------------------------------------
# Password for the seeded admin login (phone +15025550001). Optional — falls
# back to "changeme123" if unset. Only affects local/throwaway environments;
# never run db:seed against a database with real data (see README.md).
SEED_ADMIN_PASSWORD=
